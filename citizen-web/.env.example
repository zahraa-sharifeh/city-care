# Backend API base (no trailing slash). CRA reads REACT_APP_* at build time.
PORT=3001
REACT_APP_API_URL=http://localhost:5000

# Same Web client ID as backend GOOGLE_CLIENT_ID (Google Cloud Console → OAuth 2.0 Client IDs → Web client).
# Leave unset to hide Google sign-in until configured.
REACT_APP_GOOGLE_CLIENT_ID=
