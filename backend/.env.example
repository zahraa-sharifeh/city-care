PORT=5000

# Local MongoDB (docker-compose / Compass on 127.0.0.1):
# MONGO_URI=mongodb://127.0.0.1:27017/smart-city

# MongoDB Atlas — paste from Atlas → Connect → Drivers. MUST include a database name:
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/smart-city?retryWrites=true&w=majority
MONGO_URI=

# Production: comma-separated Netlify (or other) frontend URLs, e.g.
# CORS_ORIGIN=https://your-citizen.netlify.app,https://your-admin.netlify.app
# Set the SAME MONGO_URI on Render (Environment) as in this file when seeding locally.
CORS_ORIGIN=
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Google Sign-In (citizen web). Create an OAuth 2.0 "Web client" in Google Cloud Console and paste the client ID.
# Same value as citizen REACT_APP_GOOGLE_CLIENT_ID. Optional until you enable the button in production.
GOOGLE_CLIENT_ID=

# Optional: password used by npm run seed:admins for every new admin (default is ChangeMe123!)
SEED_ADMIN_PASSWORD=

# Temporary: enables POST /api/admin/setup-create + admin-web /create-admin.
# Remove when you no longer need to create admins from the UI.
ADMIN_SETUP_TOKEN=

# Optional: send citizen emails when report status changes
EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_PREVIEW_MODE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Optional: rate limits (see backend/src/middleware/rateLimits.js)
# RATE_LIMIT_AUTH_MAX=60
# RATE_LIMIT_ADMIN_LOGIN_MAX=40
# RATE_LIMIT_CREATE_REPORT_MAX=45

# Optional: max rows for GET /api/admin/reports/export.pdf (default 200, cap 500)
# ADMIN_EXPORT_MAX_ROWS=200
