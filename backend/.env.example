PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/smart-city
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Optional: password used by npm run seed:admins for every new admin (default is ChangeMe123!)
SEED_ADMIN_PASSWORD=

# Temporary: enables POST /api/admin/setup-create + admin-web /create-admin.
# Remove when you no longer need to create admins from the UI.
ADMIN_SETUP_TOKEN=
